#!/bin/bash

set -e

screenshot_path="${HOME}/Pictures/screenshots"
mkdir -p "${screenshot_path}"

the_time="$(date +%Y%m%d-%H%M%S)"
filename="${the_time}.png"
i=1
while [[ -f "${screenshot_path}/${filename}" ]]; do
    filename="${the_time}-${i}.png"
    ((i++))
done

filepath="${screenshot_path}/${filename}"
maim | tee "$filepath" | xclip -i -selection clipboard -t image/png
notify-send "Screenshot saved and copied."
